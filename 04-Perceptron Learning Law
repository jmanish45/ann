The perceptron learning algorithm updates weights iteratively based on prediction error to classify linearly separable data. 
The decision boundary separates different output classes in the feature space.”

import numpy as np
import matplotlib.pyplot as plt
from sklearn.datasets import load_iris

# Load dataset
data = load_iris()

# Features
x = data.data[:, [0,2]]

# Output classes
y = np.where(data.target == 0, 0, 1)

# Weight and bias
w = np.zeros(2)
b = 0

# Learning rate
lr = 0.1

# Epochs
epochs = 30

# Training
for epoch in range(epochs):

    for i in range(len(x)):

        yin = np.dot(x[i], w) + b

        # Activation function
        if yin >= 0:
            out = 1
        else:
            out = 0

        # Weight update
        w = w + lr * (y[i] - out) * x[i]

        # Bias update
        b = b + lr * (y[i] - out)

# Create decision region
x1_min = x[:,0].min() - 1
x1_max = x[:,0].max() + 1

x2_min = x[:,1].min() - 1
x2_max = x[:,1].max() + 1

xx1, xx2 = np.meshgrid(
    np.arange(x1_min, x1_max, 0.1),
    np.arange(x2_min, x2_max, 0.1)
)

z = []

for p in np.c_[xx1.ravel(), xx2.ravel()]:

    yin = np.dot(p, w) + b

    if yin >= 0:
        z.append(1)
    else:
        z.append(0)

z = np.array(z).reshape(xx1.shape)

# Plot graph
plt.contourf(xx1, xx2, z, alpha=0.4)

plt.scatter(x[:,0], x[:,1], c=y)

plt.xlabel("Feature 1")
plt.ylabel("Feature 2")

plt.title("Perceptron Decision Region")

plt.show()



