import numpy as np

# Neural Network Class
class ANN:

    # Initialize network
    def __init__(self, in_size, h_size, out_size):

        # Random weights
        self.w1 = np.random.randn(in_size, h_size)
        self.w2 = np.random.randn(h_size, out_size)

        # Bias values
        self.b1 = np.zeros((1, h_size))
        self.b2 = np.zeros((1, out_size))

    # Sigmoid activation function
    def sigmoid(self, x):
        return 1 / (1 + np.exp(-x))

    # Derivative of sigmoid
    def sigmoid_derivative(self, x):
        return x * (1 - x)

    # Forward propagation
    def forward(self, x):

        # Hidden layer
        self.z1 = np.dot(x, self.w1) + self.b1
        self.a1 = self.sigmoid(self.z1)

        # Output layer
        self.z2 = np.dot(self.a1, self.w2) + self.b2
        self.out = self.sigmoid(self.z2)

        return self.out

    # Backpropagation
    def backward(self, x, y, lr):

        # Output error
        error = y - self.out

        # Output delta
        d2 = error * self.sigmoid_derivative(self.out)

        # Hidden layer error
        error_hidden = d2.dot(self.w2.T)

        # Hidden delta
        d1 = error_hidden * self.sigmoid_derivative(self.a1)

        # Update output weights
        self.w2 += self.a1.T.dot(d2) * lr
        self.b2 += np.sum(d2, axis=0, keepdims=True) * lr

        # Update hidden weights
        self.w1 += x.T.dot(d1) * lr
        self.b1 += np.sum(d1, axis=0, keepdims=True) * lr

    # Training function
    def train(self, x, y, epochs, lr):

        for epoch in range(epochs):

            # Forward pass
            self.forward(x)

            # Backward pass
            self.backward(x, y, lr)

            # Print loss
            if epoch % 1000 == 0:

                loss = np.mean(np.square(y - self.out))

                print("Epoch:", epoch, "Loss:", loss)


